# PostgreSQL connection string
DATABASE_URL=postgres://clipbridge:clipbridge@localhost:5432/clipbridge

# Secret used to sign JWTs – change this in production!
JWT_SECRET=change_me_to_a_long_random_string

# HTTP port the Express server listens on
PORT=4000

# Absolute path to the frontend folder (leave blank for local default)
# On Railway set this to: /app/frontend
FRONTEND_PATH=
